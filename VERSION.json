{
  "version": "1.3.0",
  "codename": "Persistent Bot Sessions Release",
  "releaseDate": "2025-09-12",
  "features": [
    "Complete user authentication system",
    "Google OAuth integration", 
    "Telegram bot integration",
    "User data isolation",
    "Admin panel",
    "OCR ticket recognition",
    "Tournament management",
    "Telegram account linking",
    "Persistent bot sessions for webhook mode",
    "Database-backed session management",
    "Automatic session cleanup"
  ],
  "databaseVersion": "1.0.0",
  "apiVersion": "1.0.0",
  "compatibility": {
    "minimumNodeVersion": "18.0.0",
    "minimumNextJSVersion": "15.0.0",
    "supabaseVersion": "2.0.0"
  },
  "environments": {
    "development": {
      "branch": "dev",
      "database": "development",
      "features": [
        "debug",
        "hot-reload",
        "mock-data"
      ]
    },
    "staging": {
      "branch": "staging",
      "database": "staging",
      "features": [
        "testing",
        "performance-monitoring"
      ]
    },
    "production": {
      "branch": "main",
      "database": "production",
      "features": [
        "monitoring",
        "analytics",
        "backup"
      ]
    }
  },
  "rollbackInfo": {
    "previousVersion": "1.2.9",
    "rollbackAvailable": true,
    "criticalChanges": [
      "Database schema migration (bot_sessions table)",
      "Bot session middleware replacement",
      "Persistent session implementation",
      "New API endpoints for session cleanup"
    ]
  }
}

